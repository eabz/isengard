# Host interface IP this stack binds RADIUS on (must exist on the server).
HOST_BIND_IP=10.0.0.10

# Public hostname for the RADIUS server. This is the cert CN/SAN and the
# "Domain" users type on Android. Must be a real DNS name if you use a
# Let's Encrypt cert (scripts/issue-eap-cert.sh).
RADIUS_HOSTNAME=radius.cedrosnorte.edu.mx

# Shared secret your access points use (clients.conf local_lan). Must match the APs.
RADIUS_CLIENT_SECRET=change-me-to-your-ap-secret

# Google Secure LDAP access credentials (Google Admin > Apps > LDAP > client >
# access credentials). Used by both ldap_google and ldap_colegios.
GOOGLE_LDAP_IDENTITY=your-ldap-access-username
GOOGLE_LDAP_PASSWORD=your-ldap-access-password

# Google client cert still goes in raddb/certs/google/ (ldap-client.crt + .key).
# base_dn stays in raddb/mods-available/ldap_google (dc=cedrosnorte,dc=edu,dc=mx).
