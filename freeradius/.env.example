# Host interface IP this stack binds RADIUS on (must exist on the server).
HOST_BIND_IP=10.0.0.10

# Public hostname for the RADIUS server. This is the cert CN/SAN and the
# "Domain" users type on Android. Must be a real DNS name if you use a
# Let's Encrypt cert (scripts/issue-eap-cert.sh).
RADIUS_HOSTNAME=radius.cedrosnorte.edu.mx

# Google Secure LDAP credentials go in raddb/mods-available/ldap_google:
#   identity / password -> Google Admin > Apps > LDAP > client > access credentials
#   base_dn             -> primary domain only (dc=cedrosnorte,dc=edu,dc=mx)
# Google client cert goes in raddb/certs/google/ (ldap-client.crt + ldap-client.key)
