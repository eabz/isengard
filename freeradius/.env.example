# Host interface IP for this stack (must match a configured address on the server)
HOST_BIND_IP=10.0.0.10

# Google Secure LDAP — edit raddb/mods-available/ldap_google:
#   identity / password  → from Google Admin > LDAP client > access credentials
#   base_dn              → dc=yourdomain,dc=com
#   certs                → raddb/certs/google/ldap-client.crt and ldap-client.key
