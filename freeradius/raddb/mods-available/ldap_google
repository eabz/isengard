# Google Workspace Secure LDAP module for FreeRADIUS.
#
# Google Secure LDAP does NOT handle OR filters — use ldap_find_* in authorize.
# Google rejects DN bind for secondary-domain users; inner-tunnel sets LDAP-UserDn to mail.

ldap ldap_google {
	server = 'ldap://127.0.0.1'
	port = 1636

	identity = 'REPLACE_WITH_GOOGLE_LDAP_USERNAME'
	password = 'REPLACE_WITH_GOOGLE_LDAP_PASSWORD'

	base_dn = 'dc=cedrosnorte,dc=edu,dc=mx'

	# Set in authorize by ldap_find_*; authenticate binds as this mail address.
	user_dn = "LDAP-UserDn"

	group {
		base_dn = "ou=Groups,${..base_dn}"
		filter = '(objectClass=posixGroup)'
		scope = 'sub'
		name_attribute = cn
		membership_attribute = 'memberOf'
	}

	options {
		chase_referrals = no
		res_timeout = 10
		srv_timelimit = 3
		net_timeout = 3
		idle = 60
		probes = 3
		interval = 3
	}

	pool {
		start = ${thread[pool].start_servers}
		min = ${thread[pool].min_spare_servers}
		max = ${thread[pool].max_servers}
		spare = ${thread[pool].max_spare_servers}
		uses = 0
		retry_delay = 30
		lifetime = 0
		idle_timeout = 60
	}
}

# --- Authorize-only lookups (simple filters; stop on first match) ---

ldap ldap_find_cedros {
	server = 'ldap://127.0.0.1'
	port = 1636
	identity = 'REPLACE_WITH_GOOGLE_LDAP_USERNAME'
	password = 'REPLACE_WITH_GOOGLE_LDAP_PASSWORD'
	base_dn = 'dc=cedrosnorte,dc=edu,dc=mx'
	user_dn = "LDAP-UserDn"
	user {
		base_dn = "${..base_dn}"
		filter = "(mail=%{User-Name}@cedrosnorte.edu.mx)"
		scope = 'sub'
	}
}

