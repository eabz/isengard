# Google Workspace Secure LDAP module for FreeRADIUS.
#
# TLS to Google is handled by stunnel (see stunnel/google-ldap.conf).
# This avoids the GnuTLS/OpenSSL conflict in the official Docker image.
#
# Setup in Google Admin:
#   Apps > LDAP > Add client > generate access credentials + download cert/key
#   https://support.google.com/a/answer/9048434
#
# Place certificate files in raddb/certs/google/:
#   ldap-client.crt
#   ldap-client.key

ldap ldap_google {
	# Local stunnel proxy (TLS + client cert) -> ldap.google.com:636
	server = 'ldap://127.0.0.1'
	port = 1636

	# Access credentials from Google Admin (LDAP client > Generate access credentials)
	identity = 'REPLACE_WITH_GOOGLE_LDAP_USERNAME'
	password = 'REPLACE_WITH_GOOGLE_LDAP_PASSWORD'

	# Primary Google Workspace domain as DN.
	# cedrosnorte.edu.mx -> dc=cedrosnorte,dc=edu,dc=mx
	base_dn = 'dc=cedrosnorte,dc=edu,dc=mx'

	update {
		control: += 'radiusControlAttribute'
		request: += 'radiusRequestAttribute'
		reply: += 'radiusReplyAttribute'
	}

	user_dn = "LDAP-UserDn"

	user {
		# Search entire domain tree (colegios users may live outside ou=Users).
		base_dn = "${..base_dn}"
		# uid for most users; mail on both domains for secondary-domain accounts.
		filter = "(|(uid=%{Stripped-User-Name})(mail=%{Stripped-User-Name}@cedrosnorte.edu.mx)(mail=%{Stripped-User-Name}@colegios-cedros-paseo.mx))"
		scope = 'sub'
	}

	group {
		base_dn = "ou=Groups,${..base_dn}"
		filter = '(objectClass=posixGroup)'
		scope = 'sub'
		name_attribute = cn
		membership_attribute = 'memberOf'
	}

	options {
		chase_referrals = no
		res_timeout = 10
		srv_timelimit = 3
		net_timeout = 3
		idle = 60
		probes = 3
		interval = 3
	}

	pool {
		start = ${thread[pool].start_servers}
		min = ${thread[pool].min_spare_servers}
		max = ${thread[pool].max_servers}
		spare = ${thread[pool].max_spare_servers}
		uses = 0
		retry_delay = 30
		lifetime = 0
		idle_timeout = 60
	}
}

