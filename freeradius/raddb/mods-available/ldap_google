# Google Workspace Secure LDAP module for FreeRADIUS.
#
# TLS to Google is handled by stunnel (see stunnel/google-ldap.conf).
#
# cedrosnorte.edu.mx: ldap_google finds users by uid/mail at authenticate (Auth-Type LDAP).
# colegios-cedros-paseo.mx: ldap_find_colegios in inner-tunnel sets LDAP-UserDn to mail first.

ldap ldap_google {
	server = 'ldap://127.0.0.1'
	port = 1636

	identity = 'REPLACE_WITH_GOOGLE_LDAP_USERNAME'
	password = 'REPLACE_WITH_GOOGLE_LDAP_PASSWORD'

	base_dn = 'dc=cedrosnorte,dc=edu,dc=mx'

	update {
		control: += 'radiusControlAttribute'
		request: += 'radiusRequestAttribute'
		reply: += 'radiusReplyAttribute'
	}

	user_dn = "LDAP-UserDn"

	user {
		base_dn = "ou=Users,${..base_dn}"
		filter = "(|(mail=%{User-Name})(uid=%{%{Stripped-User-Name}:-%{User-Name}}))"
		scope = 'sub'
	}

	group {
		base_dn = "ou=Groups,${..base_dn}"
		filter = '(objectClass=posixGroup)'
		scope = 'sub'
		name_attribute = cn
		membership_attribute = 'memberOf'
	}

	options {
		chase_referrals = no
		res_timeout = 10
		srv_timelimit = 3
		net_timeout = 3
		idle = 60
		probes = 3
		interval = 3
	}

	pool {
		start = ${thread[pool].start_servers}
		min = ${thread[pool].min_spare_servers}
		max = ${thread[pool].max_servers}
		spare = ${thread[pool].max_spare_servers}
		uses = 0
		retry_delay = 30
		lifetime = 0
		idle_timeout = 60
	}
}

# Secondary domain only — Google needs mail bind, not LDAP DN.
ldap ldap_find_colegios {
	server = 'ldap://127.0.0.1'
	port = 1636
	identity = 'REPLACE_WITH_GOOGLE_LDAP_USERNAME'
	password = 'REPLACE_WITH_GOOGLE_LDAP_PASSWORD'
	base_dn = 'dc=cedrosnorte,dc=edu,dc=mx'
	user_dn = "Ldap-UserDn"
	user {
		base_dn = "${..base_dn}"
		filter = "(mail=%{%{Stripped-User-Name}:-%{User-Name}}@colegios-cedros-paseo.mx)"
		scope = 'sub'
	}
}
