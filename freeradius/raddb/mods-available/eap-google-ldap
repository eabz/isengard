# EAP changes required for Google Secure LDAP (EAP-TTLS + PAP).
#
# Copy these settings into mods-available/eap, or apply via the Dockerfile patch.
#
# In the main eap { } block:
#   default_eap_type = ttls
#
# In the ttls { } subsection:
#   default_eap_type = pap
#
# MS-CHAP and PEAP will NOT work with Google LDAP.
