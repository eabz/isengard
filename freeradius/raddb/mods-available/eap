# EAP for WPA2/WPA3 Enterprise against Google Secure LDAP.
#
# Outer method: EAP-TTLS. Inner method: PAP or EAP-GTC — both deliver the
# cleartext password so we can bind as the user. (iOS/Android TTLS commonly use
# inner EAP-GTC.) MS-CHAP/MS-CHAPv2 can NOT work: Google never exposes the hash.
#
# Server certificate lives in certs/eap/ (server.pem + server.key + ca.pem).
# Use a public (Let's Encrypt) cert so phones validate it with no manual CA
# install — see scripts/issue-eap-cert.sh. A self-signed cert is generated on
# first start as a fallback (scripts/gen-eap-cert.sh).

eap {
	default_eap_type = ttls
	timer_expire = 60
	ignore_unknown_eap_types = no
	cisco_accounting_username_bug = no
	max_sessions = 4096

	# Inner methods that carry a cleartext password. EAP-GTC is what iOS/Android
	# use as the inner method for EAP-TTLS here; it prompts for the password and
	# hands it to Auth-Type PAP (which the inner-tunnel binds against LDAP).
	md5 {
	}

	gtc {
		# challenge = "Password: "
		auth_type = "PAP"
	}

	tls-config tls-common {
		certificate_file = /etc/raddb/certs/eap/server.pem
		private_key_file = /etc/raddb/certs/eap/server.key
		ca_file = /etc/raddb/certs/eap/ca.pem

		# Keep each EAP-TLS fragment under the client link MTU. The APs here
		# advertise Framed-MTU = 1002, but fragment_size = 1024 made the server
		# emit ~1008-byte EAP frames — larger than 1002 — and some clients
		# (older Windows / certain drivers) then can't reassemble the server
		# Certificate, so they stall right after it and loop connect/disconnect
		# forever (never completing, so no TLS session ever gets cached). 970
		# stays safely under 1002 with headroom for EAP/RADIUS overhead. Raise
		# toward 1000 only if every client is happy; lower if any still stall.
		fragment_size = 970
		include_length = yes

		# Force modern TLS; phones and laptops all support 1.2.
		tls_min_version = "1.2"
		tls_max_version = "1.2"

		# Session resumption: a reauth/reconnect reuses the cached TLS session,
		# skipping BOTH the full handshake and the inner LDAP bind — so reauth is
		# instant and never drops the client. max_entries must be >= the number of
		# devices on the network, or sessions get evicted and fall back to a slow
		# full reauth (the usual cause of reauth disconnects). Default is only 255.
		cache {
			enable = yes
			lifetime = 48      # hours (>= Session-Timeout, which is 2 days)
			max_entries = 16384
		}

		verify {
		}
	}

	# Bare EAP-TLS (not used for WiFi here, but required so tls-common loads).
	tls {
		tls = tls-common
	}

	# EAP-TTLS: TLS tunnel, inner PAP handled by the inner-tunnel virtual server.
	ttls {
		tls = tls-common
		default_eap_type = gtc
		copy_request_to_tunnel = yes
		use_tunneled_reply = no
		virtual_server = "inner-tunnel"
	}
}
