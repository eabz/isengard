# Strip @domain from email-style logins before Google LDAP lookup.
# Google uid is "eberrueta", not "eberrueta@cedrosnorte.edu.mx".
# Keep User-Name unchanged (mail= filter in ldap_google needs full email when provided).
google_ldap_strip_username {
	if (&User-Name =~ /^([^@]+)@/) {
		update request {
			&Stripped-User-Name := "%{tolower:%{1}}"
		}
	}
	else {
		update request {
			&Stripped-User-Name := "%{tolower:%{User-Name}}"
		}
	}
}
