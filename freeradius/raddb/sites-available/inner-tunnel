# Inner tunnel for EAP-TTLS + PAP against Google Secure LDAP.
#
# The phone sends its username + password (PAP) inside the TLS tunnel; that lands
# here. We normalize the username to a bare lowercase uid, look the user up in
# Google LDAP, then bind as that user to verify the password.

server inner-tunnel {

	listen {
		ipaddr = 127.0.0.1
		port = 18120
		type = auth
	}

	authorize {
		filter_username
		filter_inner_identity

		# Username only: accept "jpsanchez" or "jpsanchez@<anydomain>" and reduce
		# to the bare lowercase uid that Google LDAP indexes.
		if (&User-Name =~ /^([^@]+)@/) {
			update request {
				&Stripped-User-Name := "%{tolower:%{1}}"
			}
		}
		else {
			update request {
				&Stripped-User-Name := "%{tolower:%{User-Name}}"
			}
		}

		# Find the user (cedrosnorte + colegios share one tree).
		ldap_google

		# If found and a password is present, authenticate by binding as the user.
		if ((ok || updated) && &User-Password && !&control:Auth-Type) {
			update control {
				&Auth-Type := LDAP
			}
		}
	}

	authenticate {
		Auth-Type LDAP {
			ldap_google
		}

		eap
	}

	session {
	}

	post-auth {
		Post-Auth-Type REJECT {
			attr_filter.access_reject

			update outer.session-state {
				&Module-Failure-Message := &request:Module-Failure-Message
			}
		}
	}
}
