# Inner tunnel for EAP-TTLS against Google Secure LDAP.
#
# Handles both inner methods that carry a cleartext password: plain PAP and
# EAP-GTC. (MS-CHAPv2 cannot work — Google never exposes the password hash.)
# We normalize the username to a bare lowercase uid, look the user up in Google
# LDAP, then bind as that user (DN for cedros, email for colegios).

server inner-tunnel {

	listen {
		ipaddr = 127.0.0.1
		port = 18120
		type = auth
	}

	authorize {
		filter_username

		# Username only: accept "jpsanchez" or "jpsanchez@<anydomain>" and reduce
		# to the bare lowercase uid that Google LDAP indexes.
		if (&User-Name =~ /^([^@]+)@/) {
			update request {
				&Stripped-User-Name := "%{tolower:%{1}}"
			}
		}
		else {
			update request {
				&Stripped-User-Name := "%{tolower:%{User-Name}}"
			}
		}

		# Find the user FIRST (before eap), so the bind identity is ready whether
		# the phone uses plain PAP or inner EAP-GTC.
		#   cedrosnorte : found by uid  -> bind as the DN
		#   colegios    : found by mail -> bind as the email (DN bind returns 49)
		ldap_google
		if (notfound) {
			ldap_colegios
			if (ok || updated) {
				update control {
					&LDAP-UserDn := "%{tolower:%{Stripped-User-Name}}@colegios-cedros-paseo.mx"
				}
			}
		}

		# Inner EAP-GTC: drive the tunneled EAP exchange. Challenge rounds stop
		# here (handled); the final round leaves &User-Password set and the gtc
		# submodule sets Auth-Type := PAP.
		eap {
			ok = return
		}

		# Plain PAP, or GTC just delivered the password: do the LDAP bind.
		if (&User-Password && !&control:Auth-Type) {
			update control {
				&Auth-Type := LDAP
			}
		}
	}

	authenticate {
		# Both bind as &control:LDAP-UserDn (DN for cedros, email for colegios).
		Auth-Type LDAP {
			ldap_google
		}
		Auth-Type PAP {
			ldap_google
		}

		eap
	}

	session {
	}

	post-auth {
		Post-Auth-Type REJECT {
			attr_filter.access_reject
		}
	}
}
