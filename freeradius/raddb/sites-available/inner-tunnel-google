# Inner tunnel for EAP-TTLS + PAP against Google Secure LDAP.
# WiFi clients and AP must use EAP-TTLS with PAP (not PEAP / MS-CHAP).

server inner-tunnel {

	listen {
		ipaddr = 127.0.0.1
		port = 18120
		type = auth
	}

	authorize {
		filter_username

		if (&User-Name =~ /^([^@]+)@/) {
			update request {
				&Stripped-User-Name := "%{tolower:%{1}}"
			}
		}
		else {
			update request {
				&Stripped-User-Name := "%{tolower:%{User-Name}}"
			}
		}

		filter_inner_identity
		suffix

		update control {
			&Proxy-To-Realm := LOCAL
		}

		eap {
			ok = return
		}

		# colegios-cedros-paseo.mx: mail bind before cedros uid/DN path in ldap_google
		ldap_find_colegios {
			ok {
				update request {
					&LDAP-UserDn := "%{tolower:%{Stripped-User-Name}}@colegios-cedros-paseo.mx"
				}
				update control {
					&LDAP-UserDn := "%{tolower:%{Stripped-User-Name}}@colegios-cedros-paseo.mx"
				}
				ok = return
			}
		}

		if (&User-Password && !control:Auth-Type) {
			update control {
				&Auth-Type := ldap
			}
		}

		pap
	}

	authenticate {
		Auth-Type PAP {
			ldap_google
		}

		Auth-Type LDAP {
			ldap_google
		}

		eap
	}

	session {
	}

	post-auth {
		Post-Auth-Type REJECT {
			attr_filter.access_reject

			update outer.session-state {
				&Module-Failure-Message := &request:Module-Failure-Message
			}
		}
	}
}
