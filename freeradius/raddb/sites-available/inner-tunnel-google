# Inner tunnel for EAP-TTLS + PAP against Google Secure LDAP.
# WiFi clients and AP must use EAP-TTLS with PAP (not PEAP / MS-CHAP).

server inner-tunnel {

	listen {
		ipaddr = 127.0.0.1
		port = 18120
		type = auth
	}

	authorize {
		filter_username
		filter_inner_identity

		if (&User-Name =~ /^([^@]+)@/) {
			update request {
				&User-Name := "%{tolower:%{1}}"
			}
		}
		else {
			update request {
				&User-Name := "%{tolower:%{User-Name}}"
			}
		}

		ldap_find_cedros {
			ok {
				update control {
					&LDAP-UserDn := "%{User-Name}@cedrosnorte.edu.mx"
				}
				update request {
					&LDAP-UserDn := "%{User-Name}@cedrosnorte.edu.mx"
				}
				ok = return
			}
		}
		ldap_find_colegios {
			ok {
				update control {
					&LDAP-UserDn := "%{User-Name}@colegios-cedros-paseo.mx"
				}
				update request {
					&LDAP-UserDn := "%{User-Name}@colegios-cedros-paseo.mx"
				}
				ok = return
			}
		}
		ldap_find_uid {
			ok {
				update control {
					&LDAP-UserDn := &reply:mail
				}
				update request {
					&LDAP-UserDn := &reply:mail
				}
				ok = return
			}
		}

		if (!&control:LDAP-UserDn && !&request:LDAP-UserDn) {
			reject
		}

		update control {
			&Proxy-To-Realm := LOCAL
			&Auth-Type := PAP
		}
	}

	authenticate {
		Auth-Type PAP {
			ldap_google
		}
	}

	session {
	}

	post-auth {
		Post-Auth-Type REJECT {
			attr_filter.access_reject

			update reply {
				&Reply-Message := &request:Module-Failure-Message
			}

			update outer.session-state {
				&Module-Failure-Message := &request:Module-Failure-Message
			}
		}
	}
}
