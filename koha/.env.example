# Host interface IP for this stack (must match a configured address on the server)
HOST_BIND_IP=10.0.0.11

# Koha image tag (see https://hub.docker.com/r/teogramm/koha/tags)
KOHA_VERSION=24.11

# Database credentials (also used for initial Koha admin login)
KOHA_DB_NAME=koha_library
KOHA_DB_USER=koha_library
KOHA_DB_PASSWORD=changeme
MARIADB_ROOT_PASSWORD=changeme
